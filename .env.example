# ─────────────────────────────────────────────────────────────
# Product Datasheet Tool — environment configuration
# Copy to `.env` and fill in. On Railway, set these as service variables.
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000
# Arbitrary identifier for this app instance (also exposed to the client).
VITE_APP_ID=product-datasheet-tool

# ── Database (MySQL) ──────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# On Railway: add a MySQL plugin and reference its connection URL.
DATABASE_URL=mysql://root:password@localhost:3306/datasheets

# ── Session / Auth ────────────────────────────────────────────
# Secret used to sign JWT session cookies. Generate a strong random value:
#   openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# openId of the account that owns the app. The team-code login and the
# "no login required" fallback both sign in as this user. Must match a row
# in the `users` table (see the seeding step in SETUP).
OWNER_OPEN_ID=owner

# Shared access code for the team login (/api/team-login). Anyone with this
# code signs in as the owner account. Leave empty to disable team login.
TEAM_ACCESS_CODE=change-me

# ── Manus OAuth (OPTIONAL) ────────────────────────────────────
# Only needed if you want real per-user Manus OAuth login. When running
# independently with team-code login, leave BOTH empty.
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=

# ── Object storage (S3 / Cloudflare R2) ───────────────────────
# Used for product/template image uploads.
S3_BUCKET=datasheet-uploads
# For AWS S3 use the bucket region (e.g. eu-central-1). For R2 use "auto".
S3_REGION=auto
# Cloudflare R2: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# AWS S3: leave empty to use the default endpoint.
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public base URL under which uploaded objects are served (rendered in <img>).
# R2: your public bucket URL or custom domain, e.g. https://cdn.example.com
# AWS S3 (public bucket): https://<BUCKET>.s3.<REGION>.amazonaws.com
# If left empty, the app falls back to time-limited presigned URLs (7 days).
S3_PUBLIC_URL_BASE=
# Set to "true" for R2/MinIO-style path addressing if needed.
S3_FORCE_PATH_STYLE=false
